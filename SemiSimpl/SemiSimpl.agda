open import Utils

-- Minimal type theory for describing semi-simplicial types
-- Originally due to AndrГЎs KovГЎcs 
-- (I translated into graph-of-the-function-style)

-- Defining the model is not easy (transport hell), but I still think it might 
-- be do-able. In an effort to avoid dealing with a bunch of path algebra, I am 
-- trying to stick only to pattern-matching on identity proofs (writing
-- helper functions to manually abstract over stuff when necessary).

module SemiSimpl.SemiSimpl where

data Top : Set
data Loc : Top вҶ’ Set
data Var : вҲҖ О“ вҶ’ Loc О“ вҶ’ Set
data Emb : вҲҖ {О“} вҶ’ Loc О“ вҶ’ Loc О“ вҶ’ Set 

variable
  О“ О” Оҳ О“' : Top
  Оһ ОЁ ОҰ О© Оһ' ОЁ' ОҰ' О©' : Loc _
  x y z : Var _ _
  Оҙ Пғ Оі Оё ПҶ ПҲ Оҙ' Пғ' Оі' Оё' ПҶ' ПҲ' ПҶ'' : Emb _ _

data _вЁҫ_вү”_ : Emb ОЁ Оһ вҶ’ Emb ОҰ ОЁ вҶ’ Emb ОҰ Оһ вҶ’ Set

variable
  Оҙрқ’ў Пғрқ’ў Оірқ’ў ПҶрқ’ў ПҲрқ’ў ПҶрқ’ў' : _ вЁҫ _ вү” _

data Top where
  вҖў   : Top
  _в–·_ : (О“ : Top) вҶ’ Loc О“ вҶ’ Top

data wkLoc_вү”_ {О“} {Оһ} : Loc О“ вҶ’ Loc (О“ в–· Оһ) вҶ’ Set

data wkEmb_вҹЁ_вҹ©вҹЁ_вҹ©вү”_ : Emb ОЁ Оһ вҶ’ wkLoc ОЁ вү” ОЁ' вҶ’ wkLoc Оһ вү” Оһ' 
                    вҶ’ Emb {О“ = О“ в–· ОҰ} ОЁ' Оһ' вҶ’ Set

variable
  Оһрқ’ў ОЁрқ’ў ОҰрқ’ў : wkLoc _ вү” _

data Loc where
  []     : Loc О“
  _-,_вҲЈ_ : (Оһ : Loc О“) вҶ’ Var О“ ОЁ вҶ’ Emb Оһ ОЁ вҶ’ Loc О“

data Emb where
  Оө     : Emb {О“} [] []
  _вҒә_вҲЈ_ : Emb Оһ ОЁ вҶ’ (x : Var О“ ОҰ) (ПҶ : Emb Оһ ОҰ) 
        вҶ’ Emb (Оһ -, x вҲЈ ПҶ) ОЁ
  _^_   : (Оҙ : Emb Оһ ОЁ) вҶ’ ПҶ вЁҫ Оҙ вү” Оі
        вҶ’ Emb (Оһ -, x вҲЈ Оі) (ОЁ -, x вҲЈ ПҶ)

data Var where
  vz : wkLoc Оһ вү” Оһ' вҶ’ Var (О“ в–· Оһ) Оһ'
  vs : Var О“ Оһ вҶ’ wkLoc Оһ вү” Оһ' вҶ’ Var (О“ в–· ОЁ) Оһ'

data wkLoc_вү”_ where
  wk[] : wkLoc [] вү” []
  wk-, : (Оҙрқ’ў : wkEmb Оҙ вҹЁ Оһрқ’ў вҹ©вҹЁ ОЁрқ’ў вҹ©вү” Оҙ')
       вҶ’ wkLoc (Оһ -, x вҲЈ Оҙ) вү” (Оһ' -, vs x ОЁрқ’ў вҲЈ Оҙ')

data _вЁҫ_вү”_ where
  вЁҫОө  : Оҙ вЁҫ Оө вү” Оҙ
  вЁҫвҒә  : Оҙ вЁҫ Пғ вү” Оі вҶ’ Оҙ вЁҫ (Пғ вҒә x вҲЈ ПҶ) вү” (Оі вҒә x вҲЈ ПҶ)
  вҒәвЁҫ^ : (Пғрқ’ў : ПҶ вЁҫ Пғ вү” ПҶ') вҶ’ Оҙ вЁҫ Пғ вү” Оі вҶ’ (Оҙ вҒә x вҲЈ ПҶ) вЁҫ (Пғ ^ Пғрқ’ў) вү” (Оі вҒә x вҲЈ ПҶ')
  ^вЁҫ^ : (Оҙрқ’ў : ПҶ вЁҫ Оҙ вү” ПҶ') (Пғрқ’ў : ПҶ' вЁҫ Пғ вү” ПҶ'') (Оірқ’ў : ПҶ вЁҫ Оі вү” ПҶ'') вҶ’ Оҙ вЁҫ Пғ вү” Оі 
      вҶ’ (_^_ {x = x} Оҙ Оҙрқ’ў) вЁҫ (Пғ ^ Пғрқ’ў) вү” (Оі ^ Оірқ’ў)

data wkEmb_вҹЁ_вҹ©вҹЁ_вҹ©вү”_ where
  wkОө : wkEmb Оө вҹЁ wk[] {Оһ = Оһ} вҹ©вҹЁ wk[] вҹ©вү” Оө
  wkвҒә : (Оҙрқ’ў : wkEmb Оҙ вҹЁ Оһрқ’ў вҹ©вҹЁ ОЁрқ’ў вҹ©вү” Оҙ')
        (ПҶрқ’ў : wkEmb ПҶ вҹЁ Оһрқ’ў вҹ©вҹЁ ОҰрқ’ў вҹ©вү” ПҶ')
      вҶ’ wkEmb (Оҙ вҒә x вҲЈ ПҶ) вҹЁ wk-, ПҶрқ’ў вҹ©вҹЁ ОЁрқ’ў вҹ©вү” (Оҙ' вҒә vs x ОҰрқ’ў вҲЈ ПҶ')
  wk^ : wkEmb Оҙ вҹЁ Оһрқ’ў вҹ©вҹЁ ОЁрқ’ў вҹ©вү” Оҙ'
      вҶ’ (ПҶрқ’ў : wkEmb ПҶ вҹЁ ОЁрқ’ў вҹ©вҹЁ ОҰрқ’ў вҹ©вү” ПҶ')
      вҶ’ (Оірқ’ў : wkEmb Оі вҹЁ Оһрқ’ў вҹ©вҹЁ ОҰрқ’ў вҹ©вү” Оі')
      вҶ’ (вЁҫОҙрқ’ў  : ПҶ  вЁҫ Оҙ  вү” Оі)
      вҶ’ (вЁҫОҙрқ’ў' : ПҶ' вЁҫ Оҙ' вү” Оі')
      вҶ’ wkEmb (_^_ {x = x} Оҙ вЁҫОҙрқ’ў) вҹЁ wk-, Оірқ’ў вҹ©вҹЁ wk-, ПҶрқ’ў вҹ©вү” (Оҙ' ^ вЁҫОҙрқ’ў')

ПҖвӮҒ : Emb ОЁ (Оһ -, x вҲЈ ПҶ) вҶ’ Emb ОЁ Оһ
ПҖвӮҒ (Оҙ вҒә y вҲЈ ПҲ) = ПҖвӮҒ Оҙ вҒә y вҲЈ ПҲ
ПҖвӮҒ (Оҙ ^ Оҙрқ’ў)    = Оҙ вҒә _ вҲЈ _

вҒәвЁҫ : (Оҙ вҒә x вҲЈ ПҶ) вЁҫ Пғ вү” Оі вҶ’ Оҙ вЁҫ ПҖвӮҒ Пғ вү” Оі
вҒәвЁҫ (вЁҫвҒә Оҙрқ’ў)     = вЁҫвҒә (вҒәвЁҫ Оҙрқ’ў)
вҒәвЁҫ (вҒәвЁҫ^ Пғрқ’ў Оірқ’ў) = вЁҫвҒә Оірқ’ў

-- I am not convinced the below utilities are useful, but they are kinda fun...
_вЁҫПҖвӮҒ_ : (ПҶ : Emb Оһ ОҰ) вҶ’ Emb ОЁ (Оһ -, x вҲЈ ПҶ) вҶ’ Emb ОЁ ОҰ
ПҶ вЁҫПҖвӮҒ (Оҙ вҒә y вҲЈ ПҲ)        = (ПҶ вЁҫПҖвӮҒ Оҙ) вҒә _ вҲЈ _
ПҶ вЁҫПҖвӮҒ (_^_ {Оі = Оі} Оҙ Оҙрқ’ў) = Оі вҒә _ вҲЈ _

ПҖвӮҒвү” : (Оҙ : Emb ОЁ (Оһ -, x вҲЈ ПҶ)) вҶ’ ПҶ вЁҫ ПҖвӮҒ Оҙ вү” (ПҶ вЁҫПҖвӮҒ Оҙ)
ПҖвӮҒвү” (Оҙ вҒә y вҲЈ ПҲ) = вЁҫвҒә (ПҖвӮҒвү” Оҙ)
ПҖвӮҒвү” (Оҙ ^ Оҙрқ’ў)    = вЁҫвҒә Оҙрқ’ў

вҹҰTopвҹ§ : SetвӮҒ
вҹҰTopвҹ§ = Set

вҹҰLocвҹ§ : вҹҰTopвҹ§ вҶ’ SetвӮҒ
вҹҰLocвҹ§ вҹҰО“вҹ§ = вҹҰО“вҹ§ вҶ’ Set

вҹҰVarвҹ§ : (вҹҰО“вҹ§ : вҹҰTopвҹ§) вҶ’ вҹҰLocвҹ§ вҹҰО“вҹ§ вҶ’ SetвӮҒ
вҹҰVarвҹ§ вҹҰО“вҹ§ вҹҰОһвҹ§ = (ПҒ : вҹҰО“вҹ§) вҶ’ вҹҰОһвҹ§ ПҒ вҶ’ Set

variable
  вҹҰО“вҹ§ вҹҰО”вҹ§ вҹҰОҳвҹ§ : вҹҰTopвҹ§
  вҹҰОһвҹ§ вҹҰОЁвҹ§ вҹҰОҰвҹ§ вҹҰОһ'вҹ§ вҹҰОЁ'вҹ§ вҹҰОҰ'вҹ§ : вҹҰLocвҹ§ _
  вҹҰxвҹ§ вҹҰyвҹ§ вҹҰzвҹ§ : вҹҰVarвҹ§ _ _

вҹҰEmbвҹ§ : вҹҰLocвҹ§ вҹҰО“вҹ§ вҶ’ вҹҰLocвҹ§ вҹҰО“вҹ§ вҶ’ Set
вҹҰEmbвҹ§ {вҹҰО“вҹ§ = вҹҰО“вҹ§} вҹҰОһвҹ§ вҹҰОЁвҹ§ = (ПҒ : вҹҰО“вҹ§) вҶ’ вҹҰОһвҹ§ ПҒ вҶ’ вҹҰОЁвҹ§ ПҒ

variable
  вҹҰОҙвҹ§ вҹҰПғвҹ§ вҹҰОівҹ§ вҹҰПҶвҹ§ вҹҰПҲвҹ§ вҹҰОҙ'вҹ§ вҹҰПғ'вҹ§ вҹҰОі'вҹ§ вҹҰПҶ'вҹ§ вҹҰПҶ''вҹ§ вҹҰПҲ'вҹ§ : вҹҰEmbвҹ§ _ _
  ОҙвүЎ ПғвүЎ ОівүЎ ОҙПғвүЎ : _вүЎ_ {A = вҹҰEmbвҹ§ _ _} _ _

вҹҰвЁҫвҹ§ : вҹҰEmbвҹ§ вҹҰОЁвҹ§ вҹҰОһвҹ§ вҶ’ вҹҰEmbвҹ§ вҹҰОҰвҹ§ вҹҰОЁвҹ§ вҶ’ вҹҰEmbвҹ§ вҹҰОҰвҹ§ вҹҰОһвҹ§
вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ вҹҰПғвҹ§ ПҒ Оҫ = вҹҰОҙвҹ§ ПҒ (вҹҰПғвҹ§ ПҒ Оҫ)

вҹҰвҖўвҹ§ : вҹҰTopвҹ§
вҹҰвҖўвҹ§ = рқҹҷ

вҹҰв–·вҹ§ : (вҹҰО“вҹ§ : вҹҰTopвҹ§) вҶ’ вҹҰLocвҹ§ вҹҰО“вҹ§ вҶ’ вҹҰTopвҹ§
вҹҰв–·вҹ§ вҹҰО“вҹ§ вҹҰОһвҹ§ = ОЈ вҹҰО“вҹ§ вҹҰОһвҹ§

вҹҰ[]вҹ§ : вҹҰLocвҹ§ вҹҰО“вҹ§
вҹҰ[]вҹ§ ПҒ = рқҹҷ

вҹҰ-,вҹ§ : (вҹҰОһвҹ§ : вҹҰLocвҹ§ вҹҰО“вҹ§) вҶ’ вҹҰVarвҹ§ вҹҰО“вҹ§ вҹҰОЁвҹ§ вҶ’ вҹҰEmbвҹ§ вҹҰОһвҹ§ вҹҰОЁвҹ§ вҶ’ вҹҰLocвҹ§ вҹҰО“вҹ§
вҹҰ-,вҹ§ вҹҰОһвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§ ПҒ = ОЈ (вҹҰОһвҹ§ ПҒ) О» Оҫ вҶ’ вҹҰxвҹ§ ПҒ (вҹҰПҶвҹ§ ПҒ Оҫ)

вҹҰОөвҹ§ : вҹҰEmbвҹ§ {вҹҰО“вҹ§ = вҹҰО“вҹ§} вҹҰ[]вҹ§ вҹҰ[]вҹ§
вҹҰОөвҹ§ ПҒ вҹЁвҹ© = вҹЁвҹ©

вҹҰвҒәвҹ§ : вҹҰEmbвҹ§ вҹҰОһвҹ§ вҹҰОЁвҹ§ вҶ’ (вҹҰxвҹ§ : вҹҰVarвҹ§ вҹҰО“вҹ§ вҹҰОҰвҹ§) (вҹҰПҶвҹ§ : вҹҰEmbвҹ§ вҹҰОһвҹ§ вҹҰОҰвҹ§)
    вҶ’ вҹҰEmbвҹ§ (вҹҰ-,вҹ§ вҹҰОһвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§) вҹҰОЁвҹ§
вҹҰвҒәвҹ§ вҹҰОҙвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§ ПҒ (Оҫ , П„) = вҹҰОҙвҹ§ ПҒ Оҫ

вҹҰ^вҹ§ : (вҹҰОҙвҹ§ : вҹҰEmbвҹ§ вҹҰОһвҹ§ вҹҰОЁвҹ§) вҶ’ вҹҰвЁҫвҹ§ вҹҰПҶвҹ§ вҹҰОҙвҹ§ вүЎ вҹҰОівҹ§
    вҶ’ вҹҰEmbвҹ§ (вҹҰ-,вҹ§ вҹҰОһвҹ§ вҹҰxвҹ§ вҹҰОівҹ§) (вҹҰ-,вҹ§ вҹҰОЁвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§)
вҹҰ^вҹ§ вҹҰОҙвҹ§ refl ПҒ (Оҫ , П„) = вҹҰОҙвҹ§ ПҒ Оҫ , П„

вҹҰПҖвӮҒвҹ§ : вҲҖ вҹҰxвҹ§ вҶ’ вҹҰEmbвҹ§ вҹҰОЁвҹ§ (вҹҰ-,вҹ§ вҹҰОһвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§) вҶ’ вҹҰEmbвҹ§ вҹҰОЁвҹ§ вҹҰОһвҹ§
вҹҰПҖвӮҒвҹ§ вҹҰxвҹ§ вҹҰОҙвҹ§ ПҒ Оҫ = вҹҰОҙвҹ§ ПҒ Оҫ .fst

вҹҰвЁҫОөвҹ§ : вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ вҹҰОөвҹ§ вүЎ вҹҰОҙвҹ§
вҹҰвЁҫОөвҹ§ = refl

вҹҰвЁҫвҒәвҹ§ : вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ вҹҰПғвҹ§ вүЎ вҹҰОівҹ§
     вҶ’ вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ (вҹҰвҒәвҹ§ вҹҰПғвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§) вүЎ вҹҰвҒәвҹ§ вҹҰОівҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§
вҹҰвЁҫвҒәвҹ§ refl = refl

вҹҰвҒәвЁҫ^вҹ§ : (ПҶвүЎ : вҹҰвЁҫвҹ§ вҹҰПҶвҹ§ вҹҰПғвҹ§ вүЎ вҹҰПҶ'вҹ§)
      вҶ’ вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ вҹҰПғвҹ§ вүЎ вҹҰОівҹ§ 
      вҶ’ вҹҰвЁҫвҹ§ (вҹҰвҒәвҹ§ вҹҰОҙвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§) (вҹҰ^вҹ§ {вҹҰxвҹ§ = вҹҰxвҹ§} вҹҰПғвҹ§ ПҶвүЎ) вүЎ вҹҰвҒәвҹ§ вҹҰОівҹ§ вҹҰxвҹ§ вҹҰПҶ'вҹ§
вҹҰвҒәвЁҫ^вҹ§ refl refl = refl
      
вҹҰ^вЁҫ^вҹ§ : (ОҙвүЎ : вҹҰвЁҫвҹ§ вҹҰПҶвҹ§ вҹҰОҙвҹ§ вүЎ вҹҰПҶ'вҹ§) (ПғвүЎ : вҹҰвЁҫвҹ§ вҹҰПҶ'вҹ§ вҹҰПғвҹ§ вүЎ вҹҰПҶ''вҹ§)
        (ОівүЎ : вҹҰвЁҫвҹ§ вҹҰПҶвҹ§ вҹҰОівҹ§ вүЎ вҹҰПҶ''вҹ§)
        (ОҙПғвүЎ : вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ вҹҰПғвҹ§ вүЎ вҹҰОівҹ§)
      -- Extra coherence
      вҶ’ ap (вҹҰвЁҫвҹ§ вҹҰПҶвҹ§) (sym ОҙПғвүЎ) вҲҷ ap (О» в–Ў вҶ’ вҹҰвЁҫвҹ§ в–Ў вҹҰПғвҹ§) ОҙвүЎ вҲҷ ПғвүЎ вүЎ ОівүЎ
      вҶ’ вҹҰвЁҫвҹ§ (вҹҰ^вҹ§ {вҹҰПҶвҹ§ = вҹҰПҶвҹ§} {вҹҰxвҹ§ = вҹҰxвҹ§} вҹҰОҙвҹ§ ОҙвүЎ) 
            (вҹҰ^вҹ§ {вҹҰxвҹ§ = вҹҰxвҹ§} вҹҰПғвҹ§ ПғвүЎ) 
      вүЎ вҹҰ^вҹ§ {вҹҰxвҹ§ = вҹҰxвҹ§} вҹҰОівҹ§ ОівүЎ
вҹҰ^вЁҫ^вҹ§ refl refl refl refl refl = refl

вҹҰвҒәвЁҫвҹ§ : вҹҰвЁҫвҹ§ (вҹҰвҒәвҹ§ вҹҰОҙвҹ§ вҹҰxвҹ§ вҹҰПҶвҹ§) вҹҰПғвҹ§ вүЎ вҹҰОівҹ§ 
     вҶ’ вҹҰвЁҫвҹ§ вҹҰОҙвҹ§ (вҹҰПҖвӮҒвҹ§ вҹҰxвҹ§ вҹҰПғвҹ§) вүЎ вҹҰОівҹ§
вҹҰвҒәвЁҫвҹ§ refl = refl

вҹҰwkLocвҹ§ : вҹҰLocвҹ§ вҹҰО“вҹ§ вҶ’ вҹҰLocвҹ§ (вҹҰв–·вҹ§ вҹҰО“вҹ§ вҹҰОЁвҹ§)
вҹҰwkLocвҹ§ вҹҰОһвҹ§ (ПҒ , П„) = вҹҰОһвҹ§ ПҒ

вҹҰwkEmbвҹ§ : вҹҰEmbвҹ§ вҹҰОЁвҹ§ вҹҰОһвҹ§ вҶ’ вҹҰwkLocвҹ§ вҹҰОЁвҹ§ вүЎ вҹҰОЁ'вҹ§ вҶ’ вҹҰwkLocвҹ§ вҹҰОһвҹ§ вүЎ вҹҰОһ'вҹ§
        вҶ’ вҹҰEmbвҹ§ {вҹҰО“вҹ§ = вҹҰв–·вҹ§ вҹҰО“вҹ§ вҹҰОҰвҹ§} вҹҰОЁ'вҹ§ вҹҰОһ'вҹ§
вҹҰwkEmbвҹ§ вҹҰОҙвҹ§ refl refl (ПҒ , П„) Оҫ = вҹҰОҙвҹ§ ПҒ Оҫ

